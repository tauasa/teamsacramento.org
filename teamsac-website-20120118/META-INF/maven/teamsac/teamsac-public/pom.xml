<?xml version="1.0" encoding="UTF-8"?>

<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
	<parent>
		<artifactId>teamsac</artifactId>
		<groupId>teamsac</groupId>
		<version>1.1</version>
	</parent>
	<modelVersion>4.0.0</modelVersion>
	<groupId>teamsac</groupId>
	<artifactId>teamsac-public</artifactId>
	<packaging>war</packaging>
	<name>teamsac-public</name>
	<description>Public interface</description>

	<dependencies>

		<!-- begin required for JBossAS 4.2.* -->
		<dependency>
			<groupId>xalan</groupId>
			<artifactId>xalan</artifactId>
			<version>2.5.1</version>
			<optional>true</optional>
		</dependency>
		
		<dependency>
			<groupId>xml-apis</groupId>
			<artifactId>xml-apis</artifactId>
			<version>1.0.b2</version>
			<optional>true</optional>
		</dependency>
		
		<dependency>
			<groupId>commons-logging</groupId>
			<artifactId>commons-logging</artifactId>
			<version>1.0.4</version>
			<optional>true</optional>
		</dependency>		
		<!-- end required for JBossAS 4.2.* -->
		
		<dependency>
			<groupId>log4j</groupId>
			<artifactId>log4j</artifactId>
			<version>1.2.13</version>
			<scope>provided</scope>
		</dependency>
		
		<dependency>
			<groupId>teamsac</groupId>
			<artifactId>teamsac-domain</artifactId>
			<version>${project.version}</version>
		</dependency>
		
		<dependency>
            <groupId>com.tauasa</groupId>
            <artifactId>tauasa-web</artifactId>
            <version>1.0</version>
        </dependency>
		
		<dependency>
			<groupId>javax.servlet</groupId>
			<artifactId>servlet-api</artifactId>
			<version>2.5</version>
			<scope>provided</scope>
		</dependency>

		<dependency>
			<groupId>javax.servlet</groupId>
			<artifactId>jsp-api</artifactId>
			<version>2.0</version>
			<scope>provided</scope>
		</dependency>

	</dependencies>

	<build>
		<plugins>
		
			<plugin>
				<groupId>com.tauasa</groupId>
				<artifactId>tauasa-maven</artifactId>
				<version>1.0</version>
				<executions>
					<!-- generate Maven build info -->
					<execution>
						<id>buildinfo</id>
						<phase>generate-resources</phase>
						<goals>
							<goal>buildinfo</goal>
						</goals>
						<configuration>
							<directory>src/main/webapp/WEB-INF</directory>
							<scmVendor>${project.scm.url}</scmVendor>
						</configuration>
					</execution>
					<!-- generate jboss-web.xml -->
					<execution>
						<id>jbossweb</id>
						<phase>generate-resources</phase>
						<goals>
							<goal>jbossweb</goal>
						</goals>
						<configuration>
							<contextRoot>/</contextRoot>
							<!--securityDomain>java:/jaas/teamsac</securityDomain-->
							<overwrite>true</overwrite>
							<flushOnSessionInvalidate>true</flushOnSessionInvalidate>
							<virtualHost>teamsacramento.net</virtualHost>
							<!--other><![CDATA[<class-loading>
							<loader-repository>org.teamsacramento.ucl:loader=TSJ</loader-repository>
							</class-loading>]]></other-->
						</configuration>
					</execution>
					<!-- copy artifact to JBoss -->
					    <execution>
						<id>copy</id>
						<phase>install</phase>
						<goals>
						    <goal>copy</goal>
						</goals>
						<configuration>
							<enabled>${copy.enabled}</enabled>
						    <directory>${local.deploy.dir}</directory>
						</configuration>
					    </execution>
				</executions>
			</plugin>

			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-war-plugin</artifactId>
				<version>2.0.1</version>
				<configuration>
					<archive>
						<manifest>
							<addClasspath>true</addClasspath>
						</manifest>
					</archive>
				</configuration>
			</plugin>

		</plugins>
	</build>

</project>