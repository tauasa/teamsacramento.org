<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE struts-config PUBLIC "-//Apache Software Foundation//DTD Struts Configuration 1.1//EN" "http://jakarta.apache.org/struts/dtds/struts-config_1_1.dtd">

<struts-config>

	<!-- Data Sources -->
	<data-sources/>

	<!-- Form Beans -->
	<form-beans>
	</form-beans>

	<!-- Global Exceptions -->
	<global-exceptions/>

	<!-- Global Forwards -->
	<global-forwards>
		<forward name="global.error.forward" path="/err/unhandled.jsp" contextRelative="true"/>				
	</global-forwards>

	<!-- Action Mappings -->
	<action-mappings>
		<!-- public news actions -->
		<action path="/news" type="org.teamsacramento.web.NewsAction" input="/index.jsp" validate="false">
			<forward name="list" contextRelative="true" path="/news.jsp"/>
			<forward name="item" contextRelative="true" path="/newsItem.jsp"/>
		</action>
		
	</action-mappings>

	<!-- Message Resources -->
	<message-resources parameter="Messages"/>
	
	<plug-in className="com.homeq.web.struts.MavenBuildInfoPlugIn">
		<set-property property="resource" value="/WEB-INF/homeq-build.properties"/>
		<set-property property="appName" value="teamsac-public"/>
	</plug-in>

</struts-config>
